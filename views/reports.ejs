<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SampahMasyarakat - Peta Sebaran Laporan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <style>
        :root { --primary: #059669; --bg: #f8fafc; }
        body { background: var(--bg); font-family: 'Inter', sans-serif; }
        
        .navbar { background: white; border-bottom: 1px solid #e2e8f0; }
        
        /* Map Container */
        #map { 
            height: 500px; 
            width: 100%; 
            border-radius: 25px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            z-index: 1;
        }

        /* Sidebar List */
        .report-side-card {
            background: white;
            border-radius: 20px;
            border: none;
            max-height: 500px;
            overflow-y: auto;
        }

        .list-group-item {
            border: none;
            border-left: 4px solid transparent;
            margin-bottom: 8px;
            transition: 0.3s;
            border-radius: 10px !important;
        }

        .list-group-item:hover {
            background: #ecfdf5;
            border-left: 4px solid var(--primary);
        }

        .status-dot {
            height: 10px;
            width: 10px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
        }

        /* Leaflet Popup Styling */
        .leaflet-popup-content-wrapper {
            border-radius: 15px;
            padding: 5px;
        }
        .popup-img {
            width: 100%;
            height: 100px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

<nav class="navbar sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold text-success" href="/"><i class="bi bi-chevron-left me-2"></i>Kembali</a>
        <span class="fw-bold text-secondary text-uppercase small">Dashboard Monitoring</span>
    </div>
</nav>

<div class="container my-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold m-0 text-slate-800">Peta Sebaran Laporan</h4>
                <div class="badge bg-success px-3 py-2 rounded-pill shadow-sm">
                    <i class="bi bi-broadcast me-1"></i> Live Data
                </div>
            </div>
            <div id="map"></div>
        </div>

        <div class="col-lg-4">
            <h4 class="fw-bold mb-3">Daftar Titik</h4>
            <div class="card report-side-card shadow-sm p-3">
                <div class="list-group list-group-flush">
                    <% if (reports.length > 0) { %>
                        <% reports.forEach(r => { %>
                            <div class="list-group-item p-3 shadow-sm border mb-2 cursor-pointer" onclick="focusMarker('<%= r.latitude %>', '<%= r.longitude %>')">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h6 class="fw-bold mb-1"><%= r.title %></h6>
                                    <% 
                                        let dotColor = '#fbbf24'; // Menunggu
                                        if(r.status === 'Selesai') dotColor = '#10b981';
                                    %>
                                    <span class="status-dot" style="background-color: <%= dotColor %>;"></span>
                                </div>
                                <p class="text-muted small mb-2 text-truncate"><%= r.location_name %></p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-secondary"><%= new Date(r.created_at).toLocaleDateString('id-ID') %></small>
                                    <a href="/reports/<%= r.id %>" class="btn btn-sm btn-outline-success border-0 fw-bold">Detail</a>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-center text-muted py-5">Belum ada data lokasi.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    // 1. Inisialisasi Peta (Default ke Bandung)
    const map = L.map('map').setView([-6.9175, 107.6191], 13);

    // 2. Tambahkan Tile Layer (Tampilan Peta)
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    // 3. Masukkan Data dari EJS ke JavaScript
    const reports = <%- JSON.stringify(reports) %>;
    const markers = {};

    // 4. Tambahkan Marker untuk setiap laporan
    reports.forEach(r => {
        if (r.latitude && r.longitude) {
            const lat = Number(r.latitude);
            const lng = Number(r.longitude);

            const marker = L.marker([lat, lng]).addTo(map);
            
            // Simpan marker ke object untuk fitur focus
            markers[`${lat},${lng}`] = marker;

            // Konten Popup
            const popupContent = `
                <div style="width: 150px;">
                    <img src="${r.image_url}" class="popup-img">
                    <h6 style="margin: 0; font-weight: bold;">${r.title}</h6>
                    <p style="font-size: 10px; color: gray; margin: 5px 0;">${r.status}</p>
                    <a href="/reports/${r.id}" class="btn btn-sm btn-success text-white w-100" style="font-size: 10px; border-radius: 5px;">Buka Detail</a>
                </div>
            `;
            marker.bindPopup(popupContent);
        }
    });

    // 5. Fungsi untuk memfokuskan peta saat list diklik
    function focusMarker(lat, lng) {
        map.setView([Number(lat), Number(lng)], 16);
        if(markers[`${lat},${lng}`]) {
            markers[`${lat},${lng}`].openPopup();
        }
    }

    // Jika ada data, arahkan peta ke laporan pertama agar tidak kosong
    if (reports.length > 0 && reports[0].latitude) {
        map.setView([Number(reports[0].latitude), Number(reports[0].longitude)], 13);
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>